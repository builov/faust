        {#}#}
    </style>
</head>
<body>
{#<h1>{{ title }}</h1>#}
{#<ol>#}
{#    {% for item in original %}#}
{#        <li class="{{ item[1] }}">{{ item[0]|raw }}</li>#}
{#    {% else %}#}
{#        <li>Список пуст</li>#}
{#    {% endfor %}#}
{#</ol>#}

<header>
    <ul id="buttons">
        {% for id, data in meta %}
            <li><a href="/?show={{ id }}" data-id="{{ id }}" class="btn">{{ data.title }}</a></li>
        {% endfor %}
    </ul>
</header>

{#<div class="grid-container" >#}

{#    {% for line in data %}#}
{#        <div class="line-num {{ item[0][1] }}">{{ loop.index }}</div>#}

{#        {% for cell in line %}#}
{#            <div class="{{ cell[1] }}">{{ cell[0]|raw }}</div>#}
{#        {% endfor %}#}
{#        #}
{#    {% else %}#}
{#        <div>Список пуст</div>#}
{#    {% endfor %}#}

{#</div>#}

{#{{ data|length }}#}

<table class="main-container">
    <thead>
        <tr>
{#            <th></th>#}
            {% for id, text in data %}
                <th data-text-id="{{ id }}"></th>
            {% endfor %}
        </tr>
    </thead>
    <tbody>
    {% for line in data|first %}
        <tr data-num="{{ loop.index0 }}" class="{{ line[1] }}">
{#            <td>#}
{#                {{ loop.index0 + 1 }}#}
{#            </td>#}
            <td>
                <div class="{{ line[1] }}">{{ line[0]|raw }}</div>
            </td>
            {% for text in data|slice(1) %}
                <td>
                    <div class="{{ text[loop.parent.loop.index0][1] }}">{{ text[loop.parent.loop.index0][0]|raw }}</div>
                </td>
            {% endfor %}
        </tr>
    {% endfor %}
    </tbody>
</table>




<script id="meta-data" type="application/json">
    {{ meta|json_encode(constant('JSON_UNESCAPED_UNICODE'))|raw }}
</script>
<script src="script2.js" defer></script>
</body>
</html>